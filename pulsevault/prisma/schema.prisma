generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VideoEvent {
  id        String   @id @default(uuid())
  videoId   String
  event     String
  userId    String
  ts        DateTime
  createdAt DateTime @default(now())

  @@map("video_events")
}

model VideoMetric {
  videoId        String @id
  watched50Count Int    @default(0)

  @@map("video_metrics")
}
